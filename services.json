    "_comment": "═══════════════════════════════════════════════════════════",
    "_note":    "SINGLE SOURCE OF TRUTH for all services.",
    "_usage":   "Loaded by services.html, ports.html, and config.js at runtime. To add a service: add an entry here, then run CFG.loadServices() — no other files need editing.",
    "_fields": {
      "id":         "Unique key — matches CFG.ports key where applicable",
      "name":       "Display name",
      "icon":       "Emoji icon",
      "tagline":    "One-line description shown in the service catalogue",
      "category":   "media | infra | apps | gaming | download | security",
      "port":       "Primary port (null if no port / Sunshine-only)",
      "portAlt":    "Secondary port if any (optional)",
      "subdomain":  "Subdomain prefix — full URL built as https://[subdomain].[CFG.domain]",
      "docker":     "true = Docker in WSL2, false = native Windows",
      "tabFile":    "HTML tab filename without .html extension",
      "tabFile2":   "Second tab if service appears in multiple tabs (optional)",
      "storage":    "Rough storage estimate for the app itself (not media libraries)",
      "cpu":        "CPU usage description at idle/light use",
      "ram":        "RAM estimate at idle/light use",
      "gpu":        "false | 'optional' | 'required'",
      "ssoMethod":  "oidc-native | oidc-plugin | forward-auth | none",
      "lanOnly":    "true = LAN access only, never publicly exposed",
      "adminOnly":  "true = used only by server owner, not regular users",
      "legacy":     "true = being phased out"
    }
  },

